{
  "name": "transport-studio",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @transport/studio dev",
    "build": "bun run typecheck && bun --filter '*' build",
    "build:packages": "bun --filter './packages/*' build",
    "build:apps": "bun --filter './apps/*' build",
    "typecheck": "bun --filter '*' typecheck",
    "typecheck:packages": "bun --filter './packages/*' typecheck",
    "typecheck:apps": "bun --filter './apps/*' typecheck",
    "lint": "bun --filter '*' lint"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
