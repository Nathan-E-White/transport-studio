{
  "name": "@transport/studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:web": "vite --host 0.0.0.0",
    "launch": "bun run tauri:dev",
    "tauri:dev": "node ../../scripts/cargo-target.mjs dev tauri dev",
    "tauri:dev:debug": "node ../../scripts/cargo-target.mjs dev tauri dev --verbose",
    "tauri:build": "node ../../scripts/cargo-target.mjs build tauri build",
    "build": "vite build",
    "build:web": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vite.config.ts",
    "test:watch": "vitest --config vite.config.ts",
    "test:app": "vitest run --config vite.config.ts src/app"
  },
  "dependencies": {
    "@transport/domain": "workspace:*",
    "@transport/frontend": "workspace:*",
    "@transport/native-execution-contract": "workspace:*",
    "@transport/shared": "workspace:*",
    "@transport/transport-worker": "workspace:*",
    "@transport/transport-visual": "workspace:*",
    "@transport/validation": "workspace:*",
    "@vitejs/plugin-react": "latest",
    "@react-three/drei": "latest",
    "@react-three/fiber": "latest",
    "@theatre/core": "latest",
    "@theatre/r3f": "latest",
    "@tauri-apps/api": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "three": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@tauri-apps/cli": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/three": "latest",
    "typescript": "^5.8.0"
  }
}
