{
  "name": "@transport/domain",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "dependencies": {
    "@transport/shared": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./compile/CompileTransportProblem": {
      "types": "./src/compile/CompileTransportProblem.ts",
      "import": "./src/compile/CompileTransportProblem.ts"
    },
    "./editor/EditorScene": {
      "types": "./src/editor/EditorScene.ts",
      "import": "./src/editor/EditorScene.ts"
    },
    "./transport/TransportGeometry": {
      "types": "./src/transport/TransportGeometry.ts",
      "import": "./src/transport/TransportGeometry.ts"
    },
    "./transport/TransportProblem": {
      "types": "./src/transport/TransportProblem.ts",
      "import": "./src/transport/TransportProblem.ts"
    },
    "./physics/PhysicsProblem": {
      "types": "./src/physics/PhysicsProblem.ts",
      "import": "./src/physics/PhysicsProblem.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  }
}
